}\\\",\\n            \\\"\\\\t$2\\\",\\n            \\\"\\\\\\\\end{thrm}\\\"\\n        ],\\n        \\\"description\\\": \\\"Теорема (thrm), без номера\\\"\\n    },\\n\\n    \\\"Lemma\\\": {\\n        \\\"prefix\\\": \\\"Lemma\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{lemma}{${1:Название}}{}\\\",\\n            \\\"\\\\t$2\\\",\\n            \\\"\\\\\\\\end{lemma}\\\"\\n        ],\\n        \\\"description\\\": \\\"Лемма (lemma), без номера\\\"\\n    },\\n    \\n    \\\"Corollary\\\": {\\n        \\\"prefix\\\": \\\"Coroll\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{coroll}{}{}\\\",\\n            \\\"\\\\t$1\\\",\\n            \\\"\\\\\\\\end{coroll}\\\"\\n        ],\\n        \\\"description\\\": \\\"Следствие (coroll), без номера\\\"\\n    },\\n    \\n    \\\"Proof\\\": {\\n        \\\"prefix\\\": \\\"Proof\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{myproof}{}{}\\\",\\n            \\\"\\\\t$1\\\",\\n            \\\"\\\\\\\\end{myproof}\\\"\\n        ],\\n        \\\"description\\\": \\\"Доказательство (myproof), без номера\\\"\\n    },\\n    \\n    \\\"Remark\\\": {\\n        \\\"prefix\\\": \\\"Remark\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{remark}{}{}\\\",\\n            \\\"\\\\t$1\\\",\\n            \\\"\\\\\\\\end{remark}\\\"\\n        ],\\n        \\\"description\\\": \\\"Замечание (remark), без номера\\\"\\n    },\\n    \\n    \\\"Task\\\": {\\n        \\\"prefix\\\": \\\"Task\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{task}{}{}\\\",\\n            \\\"\\\\t$1\\\",\\n            \\\"\\\\\\\\end{task}\\\"\\n        ],\\n        \\\"description\\\": \\\"Задача (task), без номера\\\"\\n    },\\n    \\n    \\\"Statement\\\": {\\n        \\\"prefix\\\": \\\"Statement\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\begin{statement}{}{}\\\",\\n            \\\"\\\\t$1\\\",\\n            \\\"\\\\\\\\end{statement}\\\"\\n        ],\\n        \\\"description\\\": \\\"Утверждение (statement), без номера\\\"\\n    },\\n\\n    \\\"Template file for latex\\\": {\\n        \\\"prefix\\\": \\\"Template\\\",\\n        \\\"body\\\": [\\n            \\\"\\\\\\\\documentclass{article}\\\",\\n            \\\"\\\",\\n            \\\"% Кодировка и Язык (pdfLaTeX)\\\",\\n            \\\"\\\\\\\\usepackage[T2A]{fontenc}\\\",\\n            \\\"\\\\\\\\usepackage[utf8]{inputenc}\\\",\\n            \\\"\\\\\\\\usepackage[english,russian]{babel}\\\",\\n            \\\"\\\\\\\\usepackage{cmap}       \\\",\\n            \\\"\\\\\\\\usepackage{microtype}  \\\",\\n            \\\"\\\\\\\\usepackage{comment}    \\\",\\n            \\\"\\\\\\\\usepackage{epigraph}   \\\",\\n            \\\"\\\\\\\\usepackage{tikz-cd}    \\\",\\n            \\\"\\\",\\n            \\\"% Математика и Списки\\\",\\n            \\\"\\\\\\\\usepackage{amssymb}\\\",\\n            \\\"\\\\\\\\usepackage{amsthm}     \\\",\\n            \\\"\\\\\\\\usepackage{mathtools}  \\\",\\n            \\\"\\\\\\\\usepackage{empheq}     \\\",\\n            \\\"\\\\\\\\usepackage{enumitem}   \\\",\\n            \\\"\\\",\\n            \\\"% Графика, Код и Оформление\\\",\\n            \\\"\\\\\\\\usepackage{geometry}\\\",\\n            \\\"\\\\\\\\geometry{left=3cm, right=3cm, top=2cm, bottom=2cm}\\\",\\n            \\\"\\\\\\\\usepackage{indentfirst}\\\",\\n            \\\"\\\\\\\\usepackage{graphicx}\\\",\\n            \\\"\\\\\\\\usepackage{caption}\\\",\\n            \\\"\\\\\\\\usepackage{subcaption}\\\",\\n            \\\"\\\\\\\\usepackage{multicol}\\\",\\n            \\\"\\\\\\\\usepackage{listings}\\\",\\n            \\\"\\\\\\\\usepackage[dvipsnames]{xcolor}\\\",\\n            \\\"\\\",\\n            \\\"% Теоремы, леммы и тп\\\",\\n            \\\"\\\\\\\\usepackage[most]{tcolorbox} \\\",\\n            \\\"\\\",\\n            \\\"% Гиперссылки (Последним) \\\",\\n            \\\"\\\\\\\\usepackage{hyperref}\\\",\\n            \\\"\\\",\\n            \\\"% -----------------\\\",\\n            \\\"% --- НАСТРОЙКИ ---\\\",\\n            \\\"% -----------------\\\",\\n            \\\"\\\",\\n            \\\"% Русские счетчики \\\",\\n            \\\"\\\\\\\\makeatletter\\\",\\n            \\\"\\\\\\\\AddEnumerateCounter{\\\\\\\\asbuk}{\\\\\\\\russian@alph}{щ}\\\",\\n            \\\"\\\\\\\\AddEnumerateCounter{\\\\\\\\Asbuk}{\\\\\\\\russian@alph}{щ}\\\",\\n            \\\"\\\\\\\\makeatother\\\",\\n            \\\"\\\",\\n            \\\"\\\\\\\\lstset{\\\",\\n            \\\"    basicstyle=\\\\\\\\ttfamily\\\\\\\\small, % Code font \\\",\\n            \\\"    numbers=left,               % Lines numerations from left\\\",\\n            \\\"    numberstyle=\\\\\\\\tiny\\\\\\\\color{gray},\\\",\\n            \\\"    stepnumber=1,\\\",\\n            \\\"    numbersep=5pt,\\\",\\n            \\\"    showstringspaces=false,\\\",\\n            \\\"    keywordstyle=\\\\\\\\color{blue},  % Keywords\\\",\\n            \\\"    stringstyle=\\\\\\\\color{orange}, % Strings (in quotes)\\\",\\n            \\\"    commentstyle=\\\\\\\\color{teal},  % Comments\\\",\\n            \\\"    breaklines=true,            % Linebreak\\\",\\n            \\\"    frame=single,               % Frame around the code\\\",\\n            \\\"    rulecolor=\\\\\\\\color{black!30}\\\",\\n            \\\"}\\\",\\n            \\\"\\\",\\n            \\\"\\\\\\\\hypersetup{\\\",\\n            \\\"    colorlinks=true,       % Enable colored links\\\",\\n            \\\"    linkcolor=blue,        % Color for internal links (e.g., sections, equations)\\\",\\n            \\\"    filecolor=magenta,     % Color for linked files\\\",\\n            \\\"    urlcolor=cyan,         % Color for external hyperlinks\\\",\\n            \\\"    pdftitle={pdftitle},       % PDF metadata title\\\",\\n            \\\"}\\\",\\n            \\\"\\\",\\n            \\\"% СУХОЙ СТИЛЬ ДЛЯ tcolorbox\\\",\\n            \\\"% Стиль, который имитирует \\\\\\\\newtheorem, но сохраняет синтаксис tcolorbox.\\\",\\n            \\\"\\\\\\\\tcbset{\\\",\\n            \\\"    myboxstyle/.style={\\\",\\n            \\\"        enhanced,\\\",\\n            \\\"        breakable,\\\",\\n            \\\"        frame hidden,\\\",\\n            \\\"        boxrule=0pt,\\\",\\n            \\\"        % boxrule=3pt,\\\",\\n            \\\"        borderline west = {2pt}{0pt}{gray!20},\\\",\\n            \\\"        colback=white,\\\",\\n            \\\"        % colback=gray!5,\\\",\\n            \\\"        % colbacktitle=gray!15,\\\",\\n            \\\"        fonttitle=\\\\\\\\bfseries,\\\",\\n            \\\"        coltitle=black,\\\",\\n            \\\"        arc=0mm,\\\",\\n            \\\"        titlerule=0pt,\\\",\\n            \\\"        top=1mm,\\\",\\n            \\\"        bottom=1mm, \\\",\\n            \\\"        left=3mm,\\\",\\n            \\\"        right=0mm,\\\",\\n            \\\"        parbox=false,\\\",\\n            \\\"        boxsep=0pt,\\\",\\n            \\\"        after title = {\\\\\\\\textbf{.}},\\\",\\n            \\\"        attach title to upper={\\\\\\\\smallbreak}\\\",\\n            \\\"        % separator sign=.,\\\",\\n            \\\"    }\\\",\\n            \\\"}\\\",\\n            \\\"\\\",\\n            \\\"% ОПРЕДЕЛЕНИЯ ТЕОРЕМ \\\",\\n            \\\"\\\\\\\\newtcbtheorem[]{defn}{Определение}{myboxstyle}{defn}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[no counter]{prop}{Предложение}{myboxstyle}{prop}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[]{thrm}{Теорема}{myboxstyle}{thrm}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[no counter]{lemma}{Лемма}{myboxstyle}{lemma}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[no counter]{coroll}{Следствие}{myboxstyle}{coroll}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[no counter]{myproof}{Доказательство}{myboxstyle}{myproof}\\\",\\n            \\\"\\\",\\n            \\\"\\\\\\\\newtcbtheorem[no counter]{remark}{Замечание}{myboxstyle}{remark}\\\",\\n            \\\"\\\\\\\\newtcbtheorem[n